cff-version: 1.2.0
message: >
  If you use this software, please cite it using the metadata below.
  For derivative works (including ports to other languages such as Python or C++),
  you must retain the copyright notice and cite the associated publications listed here.

title: "RAS_MoM_2D_Point_Matching"
version: 1.0.0
doi: "10.5281/zenodo.20737063"
date-released: 2025-01-01
license: Apache-2.0

authors:
  - family-names: "Hassan"
    given-names: "Mohamed A. Moharram"
    alias: "Mohamed A. Moharram"
    orcid: "https://orcid.org/0000-0002-7118-0008"

repository-code: "https://github.com/MAlaaeldin2015/RAS_MoM_2D_Point_Matching"

abstract: >
  A Fortran 2008 implementation of two complementary electromagnetic scattering
  solvers for 2D problems: the Random Auxiliary Sources (RAS) method and the
  Method of Moments (MoM) with point matching. The code supports wideband
  solutions via Asymptotic Waveform Evaluation (AWE) using Taylor series with
  Pade approximants or Chebyshev expansions. Boundary conditions supported
  include PEC, PMC, Impedance Boundary Conditions (IBC), and dielectric
  interfaces. Multi-scatterer problems are handled via an Iterative Farfield
  Bouncing (IFB) technique. Superquadric and arbitrary 2D geometries are
  supported.

keywords:
  - "electromagnetic scattering"
  - "Method of Moments"
  - "Random Auxiliary Sources"
  - "Asymptotic Waveform Evaluation"
  - "2D scattering"
  - "Fortran"
  - "computational electromagnetics"

# =============================================================================
# Associated publications — listed in chronological order
# =============================================================================
references:

  # ---------------------------------------------------------------------------
  # 1995 — ACES Journal (IBC formulation basis — third-party reference)
  # ---------------------------------------------------------------------------
  - type: article
    title: >
      Electromagnetic scattering from two dimensional anisotropic impedance
      objects under oblique plane wave incidence
    authors:
      - family-names: "Kishk"
        given-names: "Ahmed A."
      - family-names: "Kildal"
        given-names: "Per-Simon"
    journal: "Applied Computational Electromagnetics Society Journal"
    volume: 10
    issue: 3
    start: 81
    end: 92
    year: 1995
    notes: >
      Third-party reference. The IBC boundary condition definition and MoM
      formulation implemented in this code are based on this paper (with
      corrections to typographical errors in the original). The IBC impedance
      tensor and the set_MoM_BC_matrices / set_IBC_impedance_matrices routines
      follow the formulation presented here.

