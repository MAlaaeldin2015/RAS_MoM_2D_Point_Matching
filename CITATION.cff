  # 2013 — ACES Conference (original formulation, PEC scatterers)
  # ---------------------------------------------------------------------------
  - type: conference-paper
    title: >
      Electromagnetic scattering from 2D conducting objects using equivalent
      randomly distributed sources
    authors:
      - family-names: "Moharram"
        given-names: "Mohamed A."
