-3	0.d0	-50.d0	0.d0	0.d0	0.d0	0.d0	0.d0	0.d0
-4	0.d0	-5.d0	0.d0	0.d0	0.d0	0.d0	0.d0	0.d0
-5	0.d0	0.d0	0.d0	0.d0	0.d0	0.d0	0.d0	-50.d0
