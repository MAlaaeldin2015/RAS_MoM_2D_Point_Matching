7 20d0 0.d0 1.d0 0.d0
8 40d0 0.d0 1.d0 0.d0
9 80d0 0.d0 1.d0 0.d0
10 1.d0 -0.2d0 2.d0 -0.1d0
11 -1.d0 -0.1d0 -1.d0 -0.1d-0
12 -2.d0 -1.d-2 -2.d0 1.0d0
13 -1.d0 -1.0d-3 -1.d0 0.0d0
14 -1.d0 -1.0d0 -1.d0 -0.2d0
